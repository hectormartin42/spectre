echo -e "${GREEN}[*]${RESET} Installing spc CLI..."
pip install --quiet --user click
pip install --quiet --user -e /opt/spectre 2>/dev/null || true

echo -e "${GREEN}[*]${RESET} Ready. Run ${CYAN}spc${RESET} to get started.\n"
echo -e "  ${CYAN}spc workspace web${RESET}      ‚ÄĒ launch web pentesting workspace"
echo -e "  ${CYAN}spc workspace network${RESET}  ‚ÄĒ launch network recon workspace"
